TERRAFORM_VERSION="1.11.1"
DOCKERCOMPOSE_VERSION="v2.32.2"
HOME="/home/vagrant"
APP_ENV=dev

# network
VAULT_NET_NAME=vault-dev
VAULT_SUBNET=172.18.10.16/28
VAULT_IP_RANGE=172.18.10.16/28
VAULT_GATEWAY=172.18.10.17

# service
VAULT_IMAGE=vault:1.11.11
VAULT_CONTAINER_NAME=vault
VAULT_PORT=8200
VAULT_DEV_ROOT_TOKEN_ID=dev